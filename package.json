{
  "name": "action-deploy-theme",
  "version": "2.0.0",
  "repository": "git@github.com:TryGhost/action-deploy-theme.git",
  "author": "Ghost Foundation",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build": "rollup --config rollup.config.js",
    "lint": "eslint . --ignore-pattern dist --ext .js --cache",
    "preship": "yarn build && yarn lint",
    "ship": "STATUS=$(git status --porcelain); echo $STATUS; if [ -z \"$STATUS\" ]; then yarn version && git push --follow-tags; fi"
  },
  "files": [
    "index.js",
    "lib"
  ],
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "eslint": "8.57.1",
    "eslint-plugin-ghost": "3.5.0",
    "rollup": "^4.61.1"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@tryghost/admin-api": "1.14.9",
    "slug": "11.0.1"
  },
  "packageManager": "yarn@4.16.0"
}
