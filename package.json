{
  "name": "action-deploy-theme",
  "version": "2.0.3",
  "license": "MIT",
  "author": "Ghost Foundation",
  "repository": "git@github.com:TryGhost/action-deploy-theme.git",
  "files": [
    "dist",
    "action.yml"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts",
    "lint": "oxlint --quiet && oxfmt --check .",
    "lint:fix": "oxlint --fix && oxfmt .",
    "format": "oxfmt .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.test.json",
    "preship": "pnpm typecheck && pnpm lint && pnpm test:coverage && pnpm build",
    "ship": "pro-ship"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@tryghost/admin-api": "1.14.11",
    "@vercel/ncc": "0.44.1",
    "slug": "11.0.1"
  },
  "devDependencies": {
    "@tryghost/pro-ship": "1.1.5",
    "@types/node": "25.9.5",
    "@types/slug": "5.0.9",
    "@vitest/coverage-v8": "4.1.10",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.11.0"
}
