{
  "name": "action-deploy-theme",
  "version": "2.0.1",
  "license": "MIT",
  "author": "Ghost Foundation",
  "repository": "git@github.com:TryGhost/action-deploy-theme.git",
  "files": [
    "dist",
    "action.yml"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts",
    "lint": "oxlint && oxfmt --check .",
    "lint:fix": "oxlint --fix && oxfmt .",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "preship": "pnpm typecheck && pnpm lint && pnpm build",
    "ship": "STATUS=$(git status --porcelain); echo $STATUS; if [ -z \"$STATUS\" ]; then pnpm version \"${BUMP:-patch}\" && git push --follow-tags; fi"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@tryghost/admin-api": "1.14.10",
    "@vercel/ncc": "0.38.4",
    "slug": "11.0.1"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "@types/slug": "5.0.9",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.5.3"
}
